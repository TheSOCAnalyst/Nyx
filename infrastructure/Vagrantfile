# infra/Vagrantfile
# Hyperviseur : KVM/QEMU via vagrant-libvirt (S0-D7)
# Provider virtualbox supprimé — voir docs/decisions.md

Vagrant.configure("2") do |config|

  # Provider par défaut : libvirt
  config.vm.provider "libvirt" do |libvirt|
    libvirt.uri = "qemu:///system"

  config.vm.synced_folder ".", "/vagrant", type: "rsync",
    rsync__exclude: [".git/", ".vagrant/"]
  end

  # ----------------------------------------------------------------
  # SOC — Ubuntu Server 24.04 — 6 Go RAM
  # Rôle : collecte logs, moteur Python (phases 1-7), Wazuh (phases 8-10)
  # ----------------------------------------------------------------
  config.vm.define "soc" do |soc|
    soc.vm.box      = "bento/ubuntu-24.04"
    soc.vm.hostname = "soc"
    soc.vm.network  "private_network", ip: "10.0.1.10",
      libvirt__network_name: "isolated"

    soc.vm.provider "libvirt" do |v|
      v.driver = "kvm"
      v.memory = 6144
      v.cpus   = 2
    end

    soc.vm.provision "shell", path: "provision/soc.sh"
  end

  # ----------------------------------------------------------------
  # Target — Debian 12 — 1 Go RAM
  # Rôle : serveur SSH cible (brute-force S1), serveur fichiers (exfil S2)
  # ----------------------------------------------------------------
  config.vm.define "target" do |t|
    t.vm.box      = "generic/debian12"
    t.vm.box_url  = "https://vagrantcloud.com/generic/boxes/debian12/versions/4.3.12/providers/libvirt/amd64/vagrant.box"
    t.vm.hostname = "target"
    t.vm.network  "private_network", ip: "10.0.1.20",
      libvirt__network_name: "isolated"

    t.vm.provider "libvirt" do |v|
      v.driver = "kvm"
      v.memory = 1024
      v.cpus   = 1
    end

    t.vm.provision "shell", path: "provision/target.sh"
  end

  # ----------------------------------------------------------------
  # Attacker — Kali Linux — 2 Go RAM
  # Rôle : simulation des scénarios d'attaque
  # Pas de provisioning automatisé — outils configurés manuellement
  # ----------------------------------------------------------------
  config.vm.define "attacker" do |a|
    a.vm.box      = "kalilinux/rolling"
    a.vm.hostname = "attacker"
    a.vm.network  "private_network", ip: "10.0.1.50",
      libvirt__network_name: "isolated"

    a.vm.provider "libvirt" do |v|
      v.driver = "kvm"
      v.memory = 2048
      v.cpus   = 2
    end
  end

end
